{
    "name": "hexlet/code",
"authors": [
        {
            "name": "Igor Bogdanov",
            "email": "batvamail@gmail.com"
        }
    ],
    "description": "Generate diff utility",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "docopt/docopt": "^1.0",
        "lstrojny/functional-php": "^1.17",
        "symfony/yaml": "^6.4",
	"symfony/string": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Differ\\": "src/"
        },
    "files": [
        "src/Parser.php",
    	"src/Differ.php",
	"src/Formatters.php",
    	"src/Formatters/Stylish.php",
    	"src/Formatters/Plain.php",
    	"src/Formatters/Json.php"
]
    },
    "bin": [
        "bin/gendiff"
    ],
    "config": {
        "bin-dir": "bin"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.11",
        "phpstan/phpstan": "^1.0",
        "psy/psysh": "^0.11"
    }
}

